{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "radiology-rush",
  "compatibility_date": "2026-05-15",
  "observability": {
    "enabled": true
  },
  "pages_build_output_dir": "./fronted/dist/",
  "assets": {
    "directory": "./fronted/dist/assets/"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
